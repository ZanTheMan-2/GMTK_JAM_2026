  m_Script: {fileID: 11500000, guid: 90da1c55e6e474a72b5f4ee90cc545af, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::dialogController
  beginOnStart: 1
  swapScene: 1
  sceneName: Home
  audioSource: {fileID: 1241221192}
  sceneManagey: {fileID: 1241221191}
  text:
  - 'Hi there, big man. '
  - 'I see you have been doing your work for a chance. '
  - "Well...that's...good\u2026 "
  - 'Umm, so how do I put this without hurting your feelings? '
  - 'HAH! LIKE I CARE ABOUT FEELINGS! Ok, buddy, here is the deal. '
  - 'Simply put, you are costing us wayyyyy too much money, and well, that is a crime
    worse than genocide. '
  - 'So HR has come up with a super smart approach! '
  - 'WE are going to replace your useless butt with AI! '
  - 'HAHAHAHAHHAHAHAHAHAHAHA '
  - 'Feels good to finally get rid of you. '
  - 'NOW GET YOUR UGLY FACE OUT OF HERE! '
  whoIsTalking:
  - Boss
  - Boss
  - Boss
  - Boss
  - Boss
