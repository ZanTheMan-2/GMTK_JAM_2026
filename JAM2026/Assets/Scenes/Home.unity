  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 90da1c55e6e474a72b5f4ee90cc545af, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::dialogController
  swapScene: 0
  sceneName: 
  audioSource: {fileID: 1735145906}
  sceneManagey: {fileID: 1735145909}
  text:
  - 'Greetings, this is your one and only landlord. '
  - 'I bet You weren''t expecting me to call so quickly. '
  - 'My connections have told me a humorous tale, though. '
  - 'I''ve heard that you lost your job because, like a total moron, an AI took over
    your post. '
  - 'Personally, I could never do that, you have to be a complete loser to lose your
    sole source of income to a robot.  '
  - 'In any case, do you want to know why some people refer to me as the IRS? '
  - 'Because I always get paid, you can''t get away from me with any amount of running,
    and I''m going to kick you out if I don''t get paid.  '
  - 'This will be your mission, so you will do this and pay close attention.  '
  - 'First, survive. If you die, I won''t receive any money.  '
  - 'Make sure you don''t miss those and that you have enough money every day to
    pay me. '
  - 'You won''t be able to go anywhere if you don''t eat and sleep to boost your
    energy.  '
  - 'You will slow down and your days will seem shorter if you don''t take care of
    your health, watch what you eat, go for walks, and so on.  '
  - 'In light of this, keep in mind that each day has a finite amount of time, so
    make the most of it.  '
  - 'Either way, good luck, kid, and take care when you''re counting down your money.  '
  whoIsTalking:
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
  - Land Lord
